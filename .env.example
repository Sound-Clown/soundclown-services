# Shared JWT signing secret used by every service. MUST be >= 32 chars (HS384).
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# Root password for the MySQL containers (auth-db, song-db, user-db).
DB_PASSWORD=root

# Cloudinary credentials for media-service uploads.
# Get them from https://console.cloudinary.com (Dashboard). Uploads fail with the
# demo placeholders below — fill in real values to test file upload.
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Jamendo client id (for song crawler)
JAMENDO_CLIENT_ID=f2f0c91e

# Services host ports
GATEWAY_PORT=8080
AUTH_PORT=8081
SONG_PORT=8082
USER_PORT=8083
SEARCH_PORT=8084
MEDIA_PORT=8085
NOTIFICATION_PORT=8086
PAYMENT_PORT=8087
REDIS_HOST_PORT=6379
ELASTICSEARCH_PORT=9200
ZIPKIN_PORT=9411
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001

# Email (notification-service) — sends the reset-password email to a REAL inbox.
# Gmail example: enable 2FA, create an App Password at https://myaccount.google.com/apppasswords
# (use that 16-char password as SMTP_PASS, NOT your normal password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_AUTH=true
SMTP_STARTTLS=true
MAIL_FROM=you@gmail.com
# Reset link target = your frontend's reset page URL (must match the FE route):
RESET_PASSWORD_URL=http://localhost:3000/reset-password
PASSWORD_RESET_TTL_MINUTES=xx

# Premium / payment (payment-service). VNPay sandbox: register a merchant at
# https://sandbox.vnpayment.vn to get TmnCode + HashSecret (test only, no real money).
PREMIUM_PRICE_VND=50000
PREMIUM_DURATION_DAYS=30
VNP_TMN_CODE=your-tmn-code
VNP_HASH_SECRET=your-hash-secret
VNP_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
# Where VNPay redirects the browser back (must reach payment-service via the gateway):
VNP_RETURN_URL=http://localhost:8080/api/payments/vnpay-return
# Where payment-service then redirects the browser (your FE result page):
PAYMENT_RESULT_URL=http://localhost:3000/payment-result

# Stripe (alternative provider — checkout via ?provider=stripe). Test mode needs NO approval:
# get a secret key (sk_test_...) at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_RETURN_URL=http://localhost:8080/api/payments/stripe-return
STRIPE_PRICE_CENTS=200
STRIPE_CURRENCY=usd
